# Copy to .env for local overrides; .env is gitignored.

# HTTP + data plane
API_ADDR=:8080
DATABASE_URL=postgres://dtq:dtq@localhost:5432/dtq?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# Filesystem root the workers use for MIME / PDF / attachments cross-stage.
# Must be writable and shared across the three worker containers.
DATA_DIR=/tmp/dtq-data

# Gotenberg HTTP endpoint (used by the render worker).
GOTENBERG_URL=http://localhost:3000

# Google OAuth — create a Desktop OAuth 2.0 Client at console.cloud.google.com,
# enable the Gmail API + Drive API, add http://localhost:8888/callback as a
# redirect URI, and add your own email as a test user.
# DO NOT COMMIT REAL VALUES. Leave these as placeholders here; keep real values
# in a local .env (gitignored) or in k8s Secrets.
GOOGLE_OAUTH_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=REPLACE_ME

# 32-byte key, base64-encoded. Generate once with:
#   openssl rand -base64 32
# This key encrypts OAuth tokens at rest in the oauth_tokens table.
# Losing the key means all saved tokens become unreadable.
TOKEN_ENCRYPTION_KEY=REPLACE_ME_32_BYTE_BASE64

# Drive root folder ID under which the date-tree will be created. Leave empty
# to land folders at the root of your Drive. To target a specific folder,
# copy its ID from the URL in drive.google.com (the trailing path segment).
DRIVE_ROOT_FOLDER_ID=

# Optional slash-delimited folder path under DRIVE_ROOT_FOLDER_ID (or Drive root
# if that's empty). The workers will create/resolve each component once and
# use the resulting folder as the parent of the YYYY/MM/DD tree.
# Example: "02_GmailBackup/DistTaskQueue Backup"
DRIVE_ROOT_PATH=

# How long a 'queued' job (with no last_error) is allowed to sit before the
# sweeper re-pushes it to its Redis stage queue. Recovers from BLPOP-to-claim
# races where a worker crashed mid-claim. Default 60 seconds.
STALE_QUEUED_THRESHOLD_SEC=60

# --- Worker tuning (worker binary) ---
# All in seconds. Defaults shown. Set only if you need to change them.
# POP_TIMEOUT is how long BLPOP blocks before returning empty; shorter = more
# responsive to SIGTERM, longer = fewer round-trips on idle queues.
WORKER_POP_TIMEOUT_SEC=30
# HEARTBEAT_TTL is the TTL on the heartbeat:<worker_id> Redis key. The sweeper
# considers a worker dead when this key is absent. Must be > 2× interval.
WORKER_HEARTBEAT_TTL_SEC=15
# HEARTBEAT_INTERVAL is how often the worker refreshes its heartbeat while
# processing a job. Shorter = faster crash detection, more Redis writes.
WORKER_HEARTBEAT_INTERVAL_SEC=5

# --- Scheduler tuning (scheduler binary) ---
# How often the scheduler polls Gmail History API for new messages per user.
# 60s default keeps latency low without stressing quota (history.list is
# cheap). Raise for busy multi-user accounts; lower if even 60s of latency
# is unacceptable and push notifications haven't been added yet.
SCHEDULER_POLL_INTERVAL_SEC=60

# --- Backfill tuning (scheduler binary, second goroutine) ---
# Safety net against missed polls and History API quirks. Runs messages.list
# with q=after:<now-window> and enqueues fetch jobs for any message IDs not
# already in processed_emails. Idempotent: pipeline_jobs unique index blocks
# duplicates of in-flight work.
# BACKFILL_INTERVAL_SEC=0 disables backfill entirely.
BACKFILL_INTERVAL_SEC=3600
BACKFILL_WINDOW_HOURS=24
